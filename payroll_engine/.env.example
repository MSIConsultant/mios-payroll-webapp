# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/payroll_db

# Application Settings
APP_NAME=Payroll Engine
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production

# API Settings
API_PREFIX=/api/v1
SECRET_KEY=your-secret-key-change-this-in-production

# CORS Settings
CORS_ORIGINS=["http://localhost:3000"]
CORS_CREDENTIALS=True
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Server Settings
HOST=0.0.0.0
PORT=8000

# Tax Configuration
TAX_YEAR=2026
TAX_METHOD=progressive

# BPJS Configuration
BPJS_ENABLED=True
BPJS_HEALTH_PERCENTAGE=4.0
BPJS_WORK_PERCENTAGE=0.24

# Logging
LOG_LEVEL=INFO
